SECRET_KEY=change-me-to-a-random-secret

# Stripe — get these from https://dashboard.stripe.com/apikeys
STRIPE_PUBLIC_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create these in the Stripe dashboard
# Monthly: $6.99/month recurring
# Annual:  $55/year recurring
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...

# Your deployed URL (used for Stripe redirect URLs)
BASE_URL=https://your-railway-domain.up.railway.app

# ── LIVE STREAM SYSTEM ────────────────────────────────────────────────────────
#
# HOW TO GO LIVE:
#   1. Set LIVE_COUNTDOWN_TO to your showtime (ISO 8601 with timezone offset)
#      Example: 2026-04-07T06:00:00-05:00  (Monday 6AM Central)
#   2. Set LIVE_STATUS = "countdown"
#      → Status bar shows live countdown, nav button pulses red
#   3. When the show starts: set LIVE_STATUS = "live"
#      → Status bar turns solid red, /live page shows embedded stream
#   4. After the show: set LIVE_STATUS = "off", clear LIVE_COUNTDOWN_TO
#
# Values: "off" | "countdown" | "live"
# Change in Railway Variables dashboard — no deploy ever needed
LIVE_STATUS=off

# Showtime for countdown (ISO 8601 with timezone offset)
# Only used when LIVE_STATUS = "countdown"
# Example: 2026-04-07T06:00:00-05:00
LIVE_COUNTDOWN_TO=

# Optional custom status bar message override
# Leave blank to use the auto-generated message for each state
LIVE_STATUS_MESSAGE=
